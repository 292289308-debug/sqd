# ============================================================
# 灵眸量化 - 环境变量模板
# 复制为 .env 后填入实际值
# ============================================================

# 数据库密码
DB_PASSWORD=sqd_dev_pwd

# Tushare Pro Token (https://tushare.pro 注册)
TUSHARE_TOKEN=your_tushare_token_here

# JWT 密钥 (生产环境必须更换)
JWT_SECRET=change_me_in_prod_use_long_random_string

# 日志级别
LOG_LEVEL=INFO

# 支付模式 (mock/jsapi/hpayer) - 实盘交易模块用
PAY_MODE=mock

# 公网访问地址 (用于生成二维码)
PUBLIC_BASE_URL=
